{
	"name": "interceptor",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"test": "vitest",
		"typecheck": "turbo typecheck",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"e2e": "npx playwright test",
		"e2e:ui": "npx playwright test --ui",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@playwright/test": "^1.52.0",
		"@types/node": "^22",
		"husky": "9.1.7",
		"lint-staged": "16.2.7",
		"turbo": "^2.7.3",
		"typescript": "5.9.3",
		"vitest": "^4.0.18"
	},
	"lint-staged": {
		"*.{js,ts,jsx,tsx,css,md}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"packageManager": "pnpm@10.11.0",
	"dependencies": {
		"patchright": "1.57.0"
	}
}
