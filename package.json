{
	"name": "interceptor",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"test": "vitest",
		"typecheck": "turbo typecheck",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"e2e": "npx playwright test",
		"e2e:ui": "npx playwright test --ui",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.7",
		"@playwright/test": "^1.58.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.5.0",
		"better-sqlite3": "^12.8.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"turbo": "^2.8.17",
		"typescript": "5.9.3",
		"vitest": "^4.1.0"
	},
	"lint-staged": {
		"*.{js,ts,jsx,tsx,css,md}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"packageManager": "pnpm@10.11.0",
	"dependencies": {
		"patchright": "1.58.2"
	}
}
