{
	"$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "warn",
				"noDocumentCookie": "warn"
			},
			"correctness": {
				"useExhaustiveDependencies": "warn"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": { "quoteStyle": "single", "semicolons": "always" }
	},
	"overrides": [
		{
			"includes": ["scripts/**/*.ts", "**/scripts/**/*.ts"],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off"
					}
				}
			}
		},
		{
			"includes": ["**/__tests__/**/*.ts", "tests/**/*.ts", "tests/**/*.tsx"],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off"
					},
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		}
	],
	"files": {
		"includes": [
			"**",
			"!**/node_modules",
			"!**/.next",
			"!**/dist",
			"!**/*.json",
			"!**/globals.css",
			"!**/playwright-report",
			"!**/coverage",
			"!**/test-results",
			"!**/data",
			"!**/.venv",
			"!**/next-env.d.ts",
			"!apps/api/src/browser.ts"
		]
	}
}
