{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"rootDir": ".",
		"outDir": "dist",
		"lib": ["dom", "dom.iterable", "esnext"],
		"jsx": "preserve",
		"module": "esnext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"incremental": true,
		"plugins": [{ "name": "next" }],
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src", "next-env.d.ts", ".next/types/**/*.ts"],
	"exclude": ["node_modules", "src/**/*.test.ts"]
}
