# ==============================================================================
# PRODUCTION ENVIRONMENT — deep-research on EC2
# ==============================================================================
# Copy to .env and fill in real values before deploying.

# Database (Docker service name as host, internal port 5432)
DATABASE_URL=postgres://deepresearch:CHANGE_ME@postgres:5432/deep_research
POSTGRES_PASSWORD=CHANGE_ME

# Auth (generate secret with: openssl rand -base64 32)
AUTH_SECRET=CHANGE_ME
AUTH_URL=https://volat.io

# Production
NODE_ENV=production
