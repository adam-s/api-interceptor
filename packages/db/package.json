{
	"name": "@volat/db",
	"version": "0.0.1",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./schema": "./src/schema/index.ts"
	},
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"generate": "drizzle-kit generate",
		"migrate": "node --import tsx src/migrate.ts",
		"push": "drizzle-kit push",
		"studio": "drizzle-kit studio",
		"setup": "pnpm run migrate && node --import tsx scripts/setup-hypertables.ts",
		"seed": "node --import tsx scripts/seed.ts"
	},
	"dependencies": {
		"bcryptjs": "^3.0.3",
		"drizzle-orm": "^0.45.1",
		"postgres": "^3.4.8"
	},
	"devDependencies": {
		"dotenv": "^16.5.0",
		"drizzle-kit": "^0.31.8",
		"tsx": "^4.19.0",
		"typescript": "5.9.3"
	}
}
